---
// src/pages/index.astro
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

// site フォルダの「1つ上」にある data.json を読み込む（= パイプラインの出力）
const raw = readFileSync(resolve(process.cwd(), '../data.json'), 'utf-8');
const items = JSON.parse(raw);
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OSS Directory</title>
  </head>
  <body>
    <main>
      <h1>OSS Directory</h1>
      <p class="count">{items.length} 件のOSS</p>

      <div class="grid">
        {
          items.map((item) => (
            <a class="card" href={item.url} target="_blank" rel="noopener">
              <div class="card-head">
                <h2>{item.full_name}</h2>
                <span class="stars">★ {item.stars.toLocaleString()}</span>
              </div>
              <p class="summary">{item.summary}</p>
              <div class="tags">
                {item.categories.map((c) => (
                  <span class="tag cat">{c}</span>
                ))}
                {item.attributes.map((a) => (
                  <span class="tag attr">{a}</span>
                ))}
              </div>
              <div class="meta">
                {item.language && <span>{item.language}</span>}
                {item.license && item.license !== 'NOASSERTION' && <span>{item.license}</span>}
              </div>
            </a>
          ))
        }
      </div>
    </main>

    <style>
      body {
        font-family: system-ui, sans-serif;
        margin: 0;
        background: #f6f7f9;
        color: #1a1a1a;
      }
      main {
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem 1rem;
      }
      h1 {
        font-size: 1.6rem;
        margin: 0 0 0.25rem;
      }
      .count {
        color: #6b7280;
        margin: 0 0 1.5rem;
        font-size: 0.9rem;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem;
      }
      .card {
        display: block;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 1rem;
        text-decoration: none;
        color: inherit;
        transition:
          box-shadow 0.15s,
          transform 0.15s;
      }
      .card:hover {
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
        transform: translateY(-2px);
      }
      .card-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.5rem;
      }
      .card h2 {
        font-size: 1rem;
        margin: 0;
        word-break: break-word;
      }
      .stars {
        color: #b8860b;
        font-size: 0.85rem;
        white-space: nowrap;
      }
      .summary {
        font-size: 0.85rem;
        color: #374151;
        line-height: 1.5;
        margin: 0.5rem 0 0.75rem;
      }
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        margin-bottom: 0.5rem;
      }
      .tag {
        font-size: 0.7rem;
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
      }
      .tag.cat {
        background: #e0e7ff;
        color: #3730a3;
      } /* カテゴリ＝青系 */
      .tag.attr {
        background: #dcfce7;
        color: #166534;
      } /* 属性＝緑系 */
      .meta {
        display: flex;
        gap: 0.75rem;
        font-size: 0.75rem;
        color: #6b7280;
      }
    </style>
  </body>
</html>
