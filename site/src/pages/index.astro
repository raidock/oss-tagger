---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const raw = readFileSync(resolve(process.cwd(), '../data.json'), 'utf-8');
const items = JSON.parse(raw);

const allCategories = [...new Set(items.flatMap((i) => i.categories))].sort();
const allAttributes = [...new Set(items.flatMap((i) => i.attributes))].sort();
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OSS Directory</title>
  </head>
  <body>
    <main>
      <h1>OSS Directory</h1>

      <section class="filters">
        <div class="filter-group">
          <span class="filter-label">カテゴリ</span>
          {
            allCategories.map((c) => (
              <button class="chip cat" data-type="category" data-value={c}>
                {c}
              </button>
            ))
          }
        </div>
        <div class="filter-group">
          <span class="filter-label">属性</span>
          {
            allAttributes.map((a) => (
              <button class="chip attr" data-type="attribute" data-value={a}>
                {a}
              </button>
            ))
          }
        </div>
      </section>

      <p class="count"><span id="count">{items.length}</span> 件のOSS</p>

      <div class="grid" id="grid">
        {
          items.map((item) => (
            <a
              class="card"
              href={item.url}
              target="_blank"
              rel="noopener"
              data-categories={item.categories.join(',')}
              data-attributes={item.attributes.join(',')}>
              <div class="card-head">
                <h2>{item.full_name}</h2>
                <span class="stars">★ {item.stars.toLocaleString()}</span>
              </div>
              <p class="summary">{item.summary}</p>
              <div class="tags">
                {item.categories.map((c) => (
                  <span class="tag cat">{c}</span>
                ))}
                {item.attributes.map((a) => (
                  <span class="tag attr">{a}</span>
                ))}
              </div>
              <div class="meta">
                {item.language && <span>{item.language}</span>}
                {item.license && item.license !== 'NOASSERTION' && <span>{item.license}</span>}
              </div>
            </a>
          ))
        }
      </div>

      <p class="empty" id="empty" hidden>条件に合うOSSがありません。</p>
    </main>

    <script is:inline>
      var selected = { category: new Set(), attribute: new Set() };
      var chips = document.querySelectorAll('.chip');
      var cards = document.querySelectorAll('.card');
      var countEl = document.getElementById('count');
      var emptyEl = document.getElementById('empty');
      chips.forEach(function (chip) {
        chip.addEventListener('click', function () {
          var type = chip.dataset.type;
          var value = chip.dataset.value;
          if (selected[type].has(value)) {
            selected[type].delete(value);
            chip.classList.remove('active');
          } else {
            selected[type].add(value);
            chip.classList.add('active');
          }
          applyFilter();
        });
      });
      function applyFilter() {
        var visible = 0;
        cards.forEach(function (card) {
          var cats = (card.dataset.categories || '').split(',').filter(Boolean);
          var attrs = (card.dataset.attributes || '').split(',').filter(Boolean);
          var catOk =
            selected.category.size === 0 ||
            [...selected.category].some(function (c) {
              return cats.includes(c);
            });
          var attrOk =
            selected.attribute.size === 0 ||
            [...selected.attribute].some(function (a) {
              return attrs.includes(a);
            });
          var show = catOk && attrOk;
          card.hidden = !show;
          if (show) visible++;
        });
        countEl.textContent = visible;
        emptyEl.hidden = visible !== 0;
      }
    </script>

    <style>
      body {
        font-family: system-ui, sans-serif;
        margin: 0;
        background: #f6f7f9;
        color: #1a1a1a;
      }
      main {
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem 1rem;
      }
      h1 {
        font-size: 1.6rem;
        margin: 0 0 1rem;
      }
      .filters {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 1.25rem;
      }
      .filter-group {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.4rem;
      }
      .filter-label {
        font-size: 0.8rem;
        color: #6b7280;
        width: 4rem;
      }
      .chip {
        font-size: 0.75rem;
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        border: 1px solid #d1d5db;
        background: #fff;
        color: #374151;
        cursor: pointer;
        transition: all 0.12s;
      }
      .chip:hover {
        border-color: #9ca3af;
      }
      .chip.cat.active {
        background: #4f46e5;
        color: #fff;
        border-color: #4f46e5;
      }
      .chip.attr.active {
        background: #16a34a;
        color: #fff;
        border-color: #16a34a;
      }
      .count {
        color: #6b7280;
        margin: 0 0 1.5rem;
        font-size: 0.9rem;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem;
      }
      .card {
        display: block;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 1rem;
        text-decoration: none;
        color: inherit;
        transition:
          box-shadow 0.15s,
          transform 0.15s;
      }
      .card:hover {
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
        transform: translateY(-2px);
      }
      .card-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.5rem;
      }
      .card h2 {
        font-size: 1rem;
        margin: 0;
        word-break: break-word;
      }
      .stars {
        color: #b8860b;
        font-size: 0.85rem;
        white-space: nowrap;
      }
      .summary {
        font-size: 0.85rem;
        color: #374151;
        line-height: 1.5;
        margin: 0.5rem 0 0.75rem;
      }
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        margin-bottom: 0.5rem;
      }
      .tag {
        font-size: 0.7rem;
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
      }
      .tag.cat {
        background: #e0e7ff;
        color: #3730a3;
      }
      .tag.attr {
        background: #dcfce7;
        color: #166534;
      }
      .meta {
        display: flex;
        gap: 0.75rem;
        font-size: 0.75rem;
        color: #6b7280;
      }
      .empty {
        color: #6b7280;
      }
    </style>
  </body>
</html>
